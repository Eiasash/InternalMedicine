{
  "name": "pnimit-mega",
  "version": "10.4.60.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bash scripts/build.sh",
    "hooks:install": "git config core.hooksPath scripts/git-hooks && echo 'âœ“ pre-commit + pre-push hooks active'",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ shared/ tests/",
    "format": "prettier --write 'src/**/*.{js,css}' 'shared/**/*.js' 'tests/**/*.js'",
    "format:check": "prettier --check 'src/**/*.{js,css}' 'shared/**/*.js' 'tests/**/*.js'",
    "verify": "node scripts/regen_manifest.cjs --check && node scripts/sync-sw-version.cjs && python3 scripts/check-innerhtml.py && python3 scripts/check-innerhtml-pieces.py && cross-env HARRISON_HEBREW_BASELINE=0 node scripts/harrison-hebrew-baseline.cjs --strict && npm test && bash scripts/build.sh",
    "build:vite": "vite build",
    "regen:manifest": "node scripts/regen_manifest.cjs",
    "regen:manifest:check": "node scripts/regen_manifest.cjs --check",
    "check:syllabus-sync": "node scripts/check-syllabus-sync.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "acorn": "^8.16.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
